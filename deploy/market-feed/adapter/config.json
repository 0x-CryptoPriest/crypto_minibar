{
  "centrifugo": {
    "api_url": "http://127.0.0.1:8000/api",
    "api_key_env": "CENTRIFUGO_HTTP_API_KEY"
  },
  "feeds": [
    {
      "name": "alltick-btc",
      "provider": "alltick",
      "endpoint": "wss://quote.alltick.co/quote-b-ws-api",
      "token_env": "ALLTICK_TOKEN",
      "heartbeat_seconds": 10,
      "subscriptions": [
        {
          "symbol": "BTCUSDT",
          "channel": "market:btc"
        }
      ]
    }
  ]
}
